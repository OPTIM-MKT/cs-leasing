---
import { Image } from "astro:assets";
import Button from "@/components/ui/Button.astro";
import car from "@/assets/car.webp";
import { whatsappLink } from "@/lib/site";

const wa = whatsappLink("Hola, me interesa conocer su inventario.");
---

<section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
  <div
    class="grid items-center gap-10 py-16 sm:py-20 lg:grid-cols-2 lg:gap-12 lg:py-24"
  >
    <div>
      <p class="text-sm font-medium text-primary">Seminuevos premium</p>
      <h1
        class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl lg:text-6xl"
      >
        El auto que buscas, con la confianza que mereces.
      </h1>
      <p class="mt-5 max-w-lg text-lg text-muted-foreground">
        Inventario seleccionado y verificado, precios claros y atención directa.
        Sin letras chiquitas, sin presiones.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <Button href="/inventario" size="lg">Ver inventario</Button>
        <Button
          href={wa}
          variant="outline"
          size="lg"
          target="_blank"
          rel="noopener">WhatsApp</Button
        >
      </div>
    </div>

    <div class="overflow-hidden rounded-lg border border-border bg-muted">
      <Image
        src={car}
        alt="Vehículo seminuevo premium"
        widths={[480, 720, 960]}
        sizes="(min-width: 1024px) 50vw, 100vw"
        class="aspect-[4/3] w-full object-cover"
        loading="eager"
      />
    </div>
  </div>
</section>
