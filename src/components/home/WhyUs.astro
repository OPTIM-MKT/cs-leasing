---
const items = [
  {
    title: "Unidades verificadas",
    description:
      "Cada vehículo pasa por una inspección de más de 150 puntos antes de publicarse.",
  },
  {
    title: "Precios transparentes",
    description:
      "El precio que ves es el precio final. Sin cargos ocultos ni sorpresas.",
  },
  {
    title: "Historial claro",
    description:
      "Documentación en regla y reporte de kilometraje y mantenimiento de cada auto.",
  },
  {
    title: "Atención directa",
    description:
      "Hablas con una persona real, no con un bot. Te acompañamos en todo el proceso.",
  },
];
---

<section class="border-y border-border bg-muted">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
      ¿Por qué C&amp;S Leasing?
    </h2>
    <div class="mt-10 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {
        items.map((item) => (
          <div>
            <div class="h-1 w-10 rounded-full bg-primary" />
            <h3 class="mt-4 text-base font-semibold">{item.title}</h3>
            <p class="mt-2 text-sm text-muted-foreground">{item.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
