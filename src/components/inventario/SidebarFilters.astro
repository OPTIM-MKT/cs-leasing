---
/**
 * SidebarFilters — the filter groups themselves (brand, transmission, fuel,
 * price). Rendered twice: fixed in the desktop sidebar and inside the mobile
 * drawer. Options are derived from the collection, never hardcoded.
 *
 * `scope` namespaces the input ids so the two instances don't collide.
 */
import { currency } from "@/lib/site";

interface Props {
  marcas: string[];
  transmisiones: string[];
  combustibles: string[];
  precioMin: number;
  precioMax: number;
  scope: "desktop" | "mobile";
}

const { marcas, transmisiones, combustibles, precioMin, precioMax, scope } =
  Astro.props;

const groups = [
  { key: "marca", label: "Marca", options: marcas },
  { key: "transmision", label: "Transmisión", options: transmisiones },
  { key: "combustible", label: "Combustible", options: combustibles },
];
---

<form data-filters class="space-y-6">
  {
    groups.map((group) => (
      <fieldset>
        <legend class="text-sm font-medium text-foreground">
          {group.label}
        </legend>
        <div class="mt-3 space-y-2">
          {group.options.map((option) => {
            const id = `${scope}-${group.key}-${option}`;
            return (
              <label
                for={id}
                class="flex cursor-pointer items-center gap-2.5 text-sm text-muted-foreground"
              >
                <input
                  id={id}
                  type="checkbox"
                  data-filter={group.key}
                  value={option}
                  class="h-4 w-4 rounded border-input accent-primary"
                />
                {option}
              </label>
            );
          })}
        </div>
      </fieldset>
    ))
  }

  <fieldset>
    <legend class="text-sm font-medium text-foreground">Precio máximo</legend>
    <div class="mt-3">
      <input
        type="range"
        data-filter="precioMax"
        min={precioMin}
        max={precioMax}
        value={precioMax}
        step="10000"
        class="w-full accent-primary"
      />
      <div class="mt-2 flex justify-between text-xs text-muted-foreground">
        <span>{currency.format(precioMin)}</span>
        <span data-price-label>{currency.format(precioMax)}</span>
      </div>
    </div>
  </fieldset>

  <button
    type="button"
    data-clear
    class="text-sm text-primary transition-colors hover:text-foreground"
  >
    Limpiar filtros
  </button>
</form>
