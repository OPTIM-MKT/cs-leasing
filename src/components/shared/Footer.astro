---
import { Image } from "astro:assets";
import { SITE, OFFICES, SOCIAL, whatsappLink } from "@/lib/site";
import logo from "@/assets/logo.avif";

const year = new Date().getFullYear();

const nav = [
  { href: "/inventario", label: "Inventario" },
  { href: "/acerca", label: "Acerca de nosotros" },
  { href: "/contacto", label: "Contacto" },
];

const wa = whatsappLink(
  "Hola, me gustaría más información sobre sus vehículos.",
);
---

<footer class="border-t border-border bg-background">
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand + social -->
      <div class="sm:col-span-2 lg:col-span-2">
        <a href="/" aria-label="C&S Leasing — Inicio">
          <Image
            src={logo}
            alt="C&S Leasing"
            height={40}
            class="h-10 w-auto object-contain"
          />
        </a>
        <p class="mt-4 max-w-xs text-sm text-muted-foreground">
          {SITE.tagline}. Seleccionamos cada unidad para ofrecerte confianza y
          transparencia en cada operación.
        </p>
        <!-- Social links -->
        <div class="mt-5 flex items-center gap-3">
          <a
            href={SOCIAL.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a
            href={SOCIAL.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
              ></path>
            </svg>
          </a>
          <a
            href={SOCIAL.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>
          <a
            href={wa}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-muted hover:text-[#25D366]"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.15h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.24 8.23Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.8-.79.97-.14.16-.29.18-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.16.04-.31-.02-.43-.06-.12-.56-1.35-.77-1.85-.2-.48-.4-.42-.56-.43l-.48-.01c-.16 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.16 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.47-.07 1.47-.6 1.68-1.18.21-.58.21-1.08.14-1.18-.06-.11-.22-.17-.47-.29Z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <p class="text-sm font-semibold text-foreground">Navegación</p>
        <ul class="mt-4 space-y-2.5">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-muted-foreground transition-colors hover:text-foreground"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Monterrey office only -->
      <div>
        <p class="text-sm font-semibold text-foreground">Oficina</p>
        <ul class="mt-4 space-y-2 text-sm text-muted-foreground">
          <li class="font-medium text-foreground">{OFFICES[0].city}</li>
          <li class="leading-relaxed">{OFFICES[0].address}</li>
          <li>
            <a
              href={`tel:${OFFICES[0].phone.replace(/\s/g, "")}`}
              class="transition-colors hover:text-foreground"
            >
              📞 Llamar
            </a>
          </li>
          <li>
            <a
              href={`mailto:${OFFICES[0].email}`}
              class="transition-colors hover:text-foreground"
            >
              ✉ {OFFICES[0].email}
            </a>
          </li>
          <li>
            <a
              href={wa}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[#25D366] transition-colors hover:text-foreground"
            >
              💬 WhatsApp
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-12 border-t border-border pt-6 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between text-xs text-muted-foreground"
    >
      <span
        >© {year} C&amp;S Leasing. Made by <a
          class="text-primary"
          href="https://optimmkt.com/"
          target="_blank"
          rel="noopener noreferrer">Optim</a
        ></span
      >
      <span>Horario de atención: {SITE.hours}</span>
    </div>
  </div>
</footer>
