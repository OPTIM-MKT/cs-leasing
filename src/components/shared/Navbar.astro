---
import { Image } from "astro:assets";
import Button from "@/components/ui/Button.astro";
import ThemeToggle from "@/components/shared/ThemeToggle.astro";
import logo from "@/assets/logo.avif";

const links = [
  { href: "/", label: "Inicio" },
  { href: "/inventario", label: "Inventario" },
  { href: "/acerca", label: "Acerca" },
  { href: "/contacto", label: "Contacto" },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header
  class="sticky top-0 z-50 border-b border-border bg-background/90 backdrop-blur"
>
  <nav
    class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8"
    aria-label="Principal"
  >
    <a href="/" class="flex items-center" aria-label="C&S Leasing — Inicio">
      <Image
        src={logo}
        alt="C&S Leasing"
        height={36}
        class="h-9 w-auto object-contain"
      />
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "text-sm transition-colors hover:text-foreground",
                isActive(link.href)
                  ? "text-foreground font-medium"
                  : "text-muted-foreground",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="hidden items-center gap-3 md:flex">
      <ThemeToggle />
      <Button href="/contacto" size="sm">Cotizar</Button>
    </div>

    <!-- Mobile right side -->
    <div class="flex items-center gap-2 md:hidden">
      <ThemeToggle />
      <button
        id="nav-toggle"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-foreground"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-border md:hidden">
    <ul class="space-y-1 px-4 py-3">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "block rounded-lg px-3 py-2.5 text-sm transition-colors hover:bg-muted",
                isActive(link.href)
                  ? "text-foreground font-medium"
                  : "text-muted-foreground",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="pt-2">
        <Button href="/contacto" size="sm" class="w-full">Cotizar</Button>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(open === false));
  });
</script>
