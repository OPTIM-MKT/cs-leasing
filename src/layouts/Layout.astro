---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { SEO } from "astro-seo";
import Navbar from "@/components/shared/Navbar.astro";
import Footer from "@/components/shared/Footer.astro";
import { SITE, whatsappLink } from "@/lib/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${SITE.name} — ${SITE.tagline}`,
  description = "Compra vehículos seminuevos premium con total confianza. Inventario seleccionado, precios claros y atención directa.",
} = Astro.props;

const wa = whatsappLink("Hola, me interesa conocer su inventario de vehículos.");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/webp" href="/ico.webp" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title,
          type: "website",
          image: "/logo.avif",
        },
      }}
    />
    <ClientRouter />
    <!-- Theme persistence: runs before paint to avoid flash -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (stored === "dark" || (!stored && prefersDark)) {
            document.documentElement.classList.add("dark");
          } else {
            document.documentElement.classList.remove("dark");
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col bg-background text-foreground">
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Global floating WhatsApp button — top right corner -->
    <a
      href={wa}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
      id="global-wa-btn"
      class="fixed top-20 right-4 z-50 flex items-center gap-2 rounded-full bg-[#25D366] px-4 py-2.5 text-white shadow-lg transition-all duration-300 hover:scale-105 hover:shadow-xl md:top-24 md:right-6"
    >
      <svg
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
        class="shrink-0"
      >
        <path
          d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.15h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.24 8.23Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.8-.79.97-.14.16-.29.18-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.16.04-.31-.02-.43-.06-.12-.56-1.35-.77-1.85-.2-.48-.4-.42-.56-.43l-.48-.01c-.16 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.16 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.47-.07 1.47-.6 1.68-1.18.21-.58.21-1.08.14-1.18-.06-.11-.22-.17-.47-.29Z"
        ></path>
      </svg>
      <span class="hidden text-sm font-semibold sm:inline">WhatsApp</span>
    </a>
  </body>
</html>
