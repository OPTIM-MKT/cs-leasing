---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import Gallery from "@/components/inventario/Gallery.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import { currency, number, whatsappLink } from "@/lib/site";

const { slug } = Astro.params;

// Fetch all vehicles and find the one matching the slug.
const vehicles = await getCollection("vehicles");
const vehicle = vehicles.find((v) => v.data.slug === slug);

if (!vehicle) {
  return Astro.redirect("/inventario");
}

const v = vehicle.data;
const { Content } = await render(vehicle);


const titulo = `${v.marca} ${v.modelo} ${v.version} ${v.año}`;

const waMessage = `Hola, me interesa el ${v.marca} ${v.modelo} ${v.version} ${v.año} (${currency.format(v.precio)}). ¿Sigue disponible?`;
const wa = whatsappLink(waMessage);
const quiero = `/contacto?vehiculo=${encodeURIComponent(`${v.marca} ${v.modelo} ${v.version} ${v.año}`)}`;

// View transition names matching the card (scoped by slug to avoid clashes).
const transitionImage = `vehicle-img-${v.slug}`;
const transitionTitle = `vehicle-title-${v.slug}`;

const specs = [
  { label: "Marca", value: v.marca },
  { label: "Modelo", value: v.modelo },
  { label: "Versión", value: v.version },
  { label: "Año", value: String(v.año) },
  { label: "Kilometraje", value: `${number.format(v.kilometraje)} km` },
  { label: "Transmisión", value: v.transmision },
  { label: "Combustible", value: v.combustible },
];
---

<Layout
  title={`${titulo} — C&S Leasing`}
  description={v.descripcion}
>
  <article class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">

    <!-- Breadcrumb -->
    <nav class="mb-6 flex items-center gap-2 text-sm text-muted-foreground" aria-label="Ruta de navegación">
      <a href="/inventario" class="transition-colors hover:text-foreground">Inventario</a>
      <span aria-hidden="true">›</span>
      <span class="text-foreground font-medium">{v.marca} {v.modelo}</span>
    </nav>

    <div class="grid gap-10 lg:grid-cols-[1fr_22rem] lg:gap-12">

      <!-- Left: image + gallery + content -->
      <div class="space-y-8">

        <!-- Hero image with view transition -->
        <div class="relative aspect-[16/9] overflow-hidden rounded-2xl bg-muted">
          <Image
            src={v.foto}
            alt={titulo}
            widths={[800, 1200, 1600]}
            sizes="(min-width: 1024px) 60vw, 100vw"
            class="h-full w-full object-cover"
            loading="eager"
            transition:name={transitionImage}
          />
          {v.destacado && (
            <div class="absolute left-4 top-4">
              <Badge variant="primary">Destacado</Badge>
            </div>
          )}
        </div>

        <!-- Photo gallery using Gallery.astro (folder name from frontmatter) -->
        {v.galeria && (
          <div>
            <h2 class="mb-4 text-lg font-semibold tracking-tight">Galería</h2>
            <Gallery name={v.galeria} />
          </div>
        )}


        <!-- Vehicle long description (Markdown body) -->
        <div class="rounded-xl border border-border p-6">
          <h2 class="mb-4 text-lg font-semibold tracking-tight">Descripción</h2>
          <div class="prose prose-sm max-w-none text-muted-foreground dark:prose-invert leading-relaxed">
            <Content />
          </div>
        </div>

      </div>

      <!-- Right: sticky details panel -->
      <aside>
        <div class="sticky top-24 space-y-6">

          <!-- Title & price -->
          <div>
            {v.destacado && (
              <span class="mb-3 inline-flex items-center rounded-md bg-primary/10 px-2.5 py-1 text-xs font-semibold text-primary">
                Destacado
              </span>
            )}
            <h1
              class="text-2xl font-bold tracking-tight sm:text-3xl"
              transition:name={transitionTitle}
            >
              {v.marca} {v.modelo}
            </h1>
            <p class="mt-1 text-base text-muted-foreground">{v.version} · {v.año}</p>
            <p class="mt-3 text-3xl font-bold text-primary">
              {currency.format(v.precio)}
            </p>
          </div>

          <!-- Specs table -->
          <div class="rounded-xl border border-border overflow-hidden">
            <dl class="divide-y divide-border text-sm">
              {specs.map((spec) => (
                <div class="flex items-center justify-between px-4 py-3">
                  <dt class="text-muted-foreground">{spec.label}</dt>
                  <dd class="font-medium text-foreground">{spec.value}</dd>
                </div>
              ))}
            </dl>
          </div>

          <!-- Equipment badges -->
          {v.equipamiento && v.equipamiento.length > 0 && (
            <div>
              <p class="mb-3 text-sm font-semibold text-foreground">Equipamiento</p>
              <ul class="flex flex-wrap gap-2">
                {v.equipamiento.map((item) => (
                  <li>
                    <Badge variant="outline">{item}</Badge>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- CTA buttons -->
          <div class="space-y-3">
            <Button href={quiero} size="lg" class="w-full">
              Lo quiero — Contactar
            </Button>
            <Button
              href={wa}
              variant="outline"
              size="lg"
              target="_blank"
              rel="noopener"
              class="w-full"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="shrink-0">
                <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.15h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.24 8.23Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.8-.79.97-.14.16-.29.18-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.16.04-.31-.02-.43-.06-.12-.56-1.35-.77-1.85-.2-.48-.4-.42-.56-.43l-.48-.01c-.16 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.16 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.47-.07 1.47-.6 1.68-1.18.21-.58.21-1.08.14-1.18-.06-.11-.22-.17-.47-.29Z"></path>
              </svg>
              Preguntar por WhatsApp
            </Button>
            <a
              href="/inventario"
              class="block text-center text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
              ← Volver al inventario
            </a>
          </div>

        </div>
      </aside>
    </div>
  </article>
</Layout>
